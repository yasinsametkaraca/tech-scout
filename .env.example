# Copy to .env and edit. The .env file is git-ignored.
# All variables are prefixed with TECH_SCOUT_.

# ---- Locale ----
# Default output language for /tech-scout runs that don't pass --language.
# Accepts en|tr|english|turkish.
# TECH_SCOUT_DEFAULT_LOCALE_CODE=en

# ---- Paths ----
# Where past research packages live (and where new ones go by default).
# TECH_SCOUT_DEFAULT_OUTPUT_ROOT=/path/to/Research Documentation

# ---- Logging ----
# json (default, machine-parseable) or console (human-readable, dev only).
# TECH_SCOUT_LOG_FORMAT=json
# TECH_SCOUT_LOG_LEVEL=INFO

# ---- Behavior tuning ----
# TECH_SCOUT_MAX_FINDINGS_PER_RUN=50
# TECH_SCOUT_MIN_CANDIDATES=8
# TECH_SCOUT_MAX_CANDIDATES=12
# TECH_SCOUT_DEFAULT_TIME_WINDOW_DAYS=7
